{
  "name": "genetics-js-mdccvrp",
  "version": "0.0.0",
  "description": "Solver for the MDCCVRP using evolutionary algorithms",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "solve": "node lib/implementation/main.js",
    "test": "jest --config jestconfig.json",
    "coverage": "jest --config jestconfig.json --coverage",
    "lint": "eslint --config .eslintrc src/",
    "lint-fix": "eslint --config .eslintrc src/ --fix",
    "format": "prettier --config .prettierrc 'src/**' --write",
    "docs": "typedoc --out docs/ src/index.ts && touch docs/.nojekyll",
    "exp:random-local": "node lib/experiment/executeExperiment.js --random-local"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ULL-ESIT-INF-TFG-2021/TFG-2021-Cristo-Daniel-Navarro-MDCCVRP.git"
  },
  "keywords": [
    "evolutionary",
    "algorithms",
    "optimization",
    "mdccvrp"
  ],
  "author": "Cristo Daniel Navarro Rodríguez <alu0101024608@ull.edu.es> (https://github.com/CristoNavarro)",
  "contributors": [
    "Eduardo Manuel Segredo González <esegredo@ull.edu.es> (https://github.com/esegredo)",
    "Casiano Rodríguez-León <crguezl@ull.edu.es> (https://github.com/crguezl)"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ULL-ESIT-INF-TFG-2021/TFG-2021-Cristo-Daniel-Navarro-MDCCVRP/issues"
  },
  "homepage": "https://github.com/ULL-ESIT-INF-TFG-2021/TFG-2021-Cristo-Daniel-Navarro-MDCCVRP#readme",
  "files": [
    "lib/**/*"
  ],
  "dependencies": {
    "genetics-js": "^1.3.0",
    "yargs": "^16.2.0"
  },
  "devDependencies": {
    "@types/jest": "^26.0.22",
    "@types/node": "^14.14.37",
    "@typescript-eslint/eslint-plugin": "^4.20.0",
    "@typescript-eslint/parser": "^4.20.0",
    "eslint": "^7.23.0",
    "eslint-config-prettier": "^7.2.0",
    "eslint-plugin-prettier": "^3.3.1",
    "jest": "^26.6.3",
    "nodeplotlib": "^0.7.3",
    "prettier": "^2.2.1",
    "ts-jest": "^26.5.4",
    "typedoc": "^0.20.34",
    "typescript": "^4.2.3"
  }
}
